# ─── Base de datos (Turso / libSQL) ───────────────────────────────────
# Local: usa un fichero SQLite. Producción (Vercel): pon la URL de Turso.
DATABASE_URL="file:./dev.db"

# Runtime libSQL (adaptador). Local -> file:./prisma/dev.db (relativo al cwd)
# Producción -> libsql://<db>.turso.io
TURSO_DATABASE_URL="file:./prisma/dev.db"
# Token de auth de Turso (vacío en local). Genéralo con: turso db tokens create <db>
TURSO_AUTH_TOKEN=""

# ─── Auth (NextAuth) ──────────────────────────────────────────────────
# Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET="genera-un-secreto-aleatorio"
# En producción: https://tu-dominio.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Credenciales del panel admin
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="una-clave-segura"

# ─── Uploads (Vercel Blob) ────────────────────────────────────────────
# Se inyecta automáticamente en Vercel al conectar un store de Blob.
# En local, tráelo con: vercel env pull
BLOB_READ_WRITE_TOKEN=""

# ─── Chatbot IA (Google Gemini) ───────────────────────────────────────
# Clave gratuita para el asistente del portafolio.
# Genérala en: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ─── WhatsApp (Twilio) ────────────────────────────────────────────────
# Solo necesario si conectas el bot a WhatsApp vía Twilio.
# Auth Token de tu cuenta Twilio: https://console.twilio.com (Account Info).
# Se usa para validar que los webhooks vienen de Twilio.
TWILIO_AUTH_TOKEN=""
# Opcional: URL pública exacta del webhook (si la validación de firma falla por
# el proxy de Vercel). Ej: https://tu-dominio.vercel.app/api/whatsapp
TWILIO_WEBHOOK_URL=""
# Opcional: pon "false" para desactivar la validación de firma (solo para pruebas).
TWILIO_VALIDATE=""
